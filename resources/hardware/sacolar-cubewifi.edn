;; Hardware descriptor — Sacolar inverter via Growatt-family CubeWiFi datalogger
;; (inverter model TBD). DATA / BUFFERED_DATA payload (type 0x04 / 0x50),
;; 349 bytes decrypted. The wire framing is shared CubeWiFi (Growatt-family);
;; only the payload offset map here is vendor-specific.
;; Source of truth: doc/protocol/sacolar-cubewifi-data-payload.md
;; New inverter model = new descriptor file, zero new code (ADR-018).

{:hardware-id :sacolar/cubewifi
 :payload-len 349

 ;; Framing — data-driven generic framer vocabulary (TDD-01). No per-protocol framing
 ;; code; the framer parses :header, derives payload_len from :length/:counts,
 ;; verifies :crc, and applies :obfuscation. Escape-hatch (:framer-fn) deferred, mirroring
 ;; the :derive escape-hatch in ADR-033.
 :framing
 {:header      [[:seq 2 :be] [:proto 2 :be] [:length 2 :be] [:unit 1] [:type 1]]
  :length      {:counts [:unit :type :payload]}    ; length = unit(1)+type(1)+payload_len ⇒ payload_len = length − 2
  :crc         {:algorithm  :crc16-modbus
                :poly        0xA001
                :init        0xFFFF
                :input-order :be
                :covers      :header+payload       ; over wire bytes (pre-XOR), excl. the 2-B trailer
                :width       2}                     ; trailing CRC width
  :obfuscation {:when        {:proto 0x0006}        ; XOR triggered when proto == 0x0006
                :algo        :xor-repeating
                :key         "Growatt"              ; 7-byte repeating key
                :applies-to  :payload}}             ; payload only; header is plaintext

 ;; Inverter serial: bytes 0–9, ASCII zero-padded (present in ANNOUNCE and DATA)
 :serial {:offset 0 :len 10 :encoding :ascii}

 ;; Inverter RTC — UTC (set via TIME_SYNC; no independent time source)
 :timestamp {:offset 60
             :fields [{:byte 60 :meaning :year-offset :base 2000}
                      {:byte 61 :meaning :month}
                      {:byte 62 :meaning :day}
                      {:byte 63 :meaning :hour}
                      {:byte 64 :meaning :minute}
                      {:byte 65 :meaning :second}]}

 ;; Confirmed field offsets — all into the decrypted payload, multi-byte big-endian.
 ;; raw-int × :scale = physical value; unit encoded in :reading-key suffix (ADR-019).
 :fields
 [{:reading-key :reading/pv1-voltage-v        :offset 73  :type :uint16-be :scale 0.1}
  {:reading-key :reading/pv2-voltage-v        :offset 75  :type :uint16-be :scale 0.1}
  {:reading-key :reading/pv1-power-w          :offset 79  :type :uint16-be :scale 0.1}
  {:reading-key :reading/pv2-power-w          :offset 83  :type :uint16-be :scale 0.1}
  {:reading-key :reading/pv1-current-a        :offset 85  :type :uint16-be :scale 0.1}
  {:reading-key :reading/pv2-current-a        :offset 87  :type :uint16-be :scale 0.1}
  {:reading-key :reading/load-power-w         :offset 91  :type :uint16-be :scale 0.1}
  {:reading-key :reading/ac-apparent-power-va :offset 95  :type :uint16-be :scale 0.1}
  {:reading-key :reading/battery-voltage-v    :offset 105 :type :uint16-be :scale 0.01}
  {:reading-key :reading/ac-input-voltage-v   :offset 111 :type :uint16-be :scale 0.1}
  {:reading-key :reading/ac-output-voltage-v  :offset 115 :type :uint16-be :scale 0.1}
  {:reading-key :reading/temp-c               :offset 121 :type :uint16-be :scale 0.1}
  {:reading-key :reading/grid-power-w         :offset 145 :type :uint16-be :scale 0.1
   :note "import only; always >= 0 (ADR-021: no export)"}
  {:reading-key :reading/energy-today-kwh     :offset 173 :type :uint16-be :scale 0.1
   :note "u16 to handle summer days >25.5 kWh; re-verify on high-yield capture (ADR-018)"}
  {:reading-key :reading/energy-total-kwh     :offset 175 :type :uint32-be :scale 0.1}
  {:reading-key :reading/ac-input-current-a   :offset 262 :type :uint16-be :scale 0.01}
  {:reading-key :reading/grid-frequency-hz    :offset 267 :type :uint16-be :scale 0.01}]

 ;; Computed fields — multi-register, codec-computed (ADR-033). Offsets live in
 ;; :inputs (the descriptor is the complete offset map); the algorithm is a pure
 ;; (payload, inputs) → value fn in ilanga.protocol.sacolar.codec, dispatched by
 ;; :fn. Decode + overflow/hysteresis logic: protocol doc "Battery power & current
 ;; decode". Scale/sign/overflow are resolved in the fn, so no :scale here.
 :compute
 [{:reading-key :reading/battery-power-w
   :fn        :ilanga.protocol.sacolar.codec/battery-power
   :inputs    {:power-mag 231 :charge-i 241 :discharge-i 243 :idle-flag 230 :hysteresis-a 0.5}}
  {:reading-key :reading/battery-current-a
   :fn        :ilanga.protocol.sacolar.codec/battery-current
   :inputs    {:charge-i 241 :discharge-i 243}}]

 ;; Derived fields — declarative ops over already-decoded Reading fields, no
 ;; payload (ADR-033). Protocol-agnostic; computed at ingest and stored as a
 ;; column (TDD-02). pv-total = pv1 + pv2.
 :derive
 [{:reading-key :reading/pv-total-power-w :op :sum
   :of [:reading/pv1-power-w :reading/pv2-power-w]}]}
